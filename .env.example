# Copie para .env e ajuste os valores. NUNCA commite o .env real.

# Ambiente: development | production
APP_ENV=development

# Porta em que a API HTTP vai escutar
APP_PORT=8080

# String de conexão do PostgreSQL.
# Formato: postgres://USUARIO:SENHA@HOST:PORTA/BANCO?sslmode=disable
# Em produção, use sslmode=require (ou verify-full).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lojinha_assets?sslmode=disable

# Segredo usado para assinar tokens JWT. Use uma string longa e aleatória
# (ex: `openssl rand -base64 64`). NUNCA reaproveite entre ambientes.
JWT_SECRET=troque-este-segredo-em-producao

# Tempo de vida do token em horas (default: 24)
JWT_TTL_HOURS=24

# Diretório raiz onde os uploads (thumbnails + modelos 3D) são gravados.
# Relativo ao CWD do processo. Default: "uploads".
UPLOAD_DIR=uploads

# Origens permitidas pelo CORS, separadas por vírgula. Em dev o Vite
# roda em :5173. Em produção, troque pelo domínio real do frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173
