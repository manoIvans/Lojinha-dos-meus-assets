# ============================================================
# Configuração da Lojinha — copie para .env e ajuste.
# ============================================================
# Este arquivo é lido pelo `docker compose` para substituir as
# variáveis ${VAR} em docker-compose.yml E também consumido como
# environment dos containers.

# Ambiente: development | production
APP_ENV=development

# ------------------------------------------------------------
# Banco de dados
# ------------------------------------------------------------
# Estas três são usadas pelo container do Postgres oficial para
# inicializar o usuário e o database na PRIMEIRA execução.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lojinha_assets

# IMPORTANTE: dentro da rede do Docker, o host é o NOME DO SERVIÇO
# (definido em docker-compose.yml) — neste caso, "postgres". NÃO use
# "localhost" aqui: dentro do container API, localhost aponta pro
# PRÓPRIO container, não pro Postgres.
#
# Se um dia for rodar a API nativa (fora do Docker) apontando pro
# Postgres do compose, troque "postgres" por "localhost" — a porta
# 5432 já está publicada no host via `ports:` no compose.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/lojinha_assets?sslmode=disable

# ------------------------------------------------------------
# Autenticação JWT
# ------------------------------------------------------------
# Segredo de assinatura dos tokens. Gere com:
#   openssl rand -base64 64
# NUNCA reaproveite entre ambientes. NUNCA commite o valor real.
JWT_SECRET=troque-este-segredo-em-producao

# TTL do token em horas
JWT_TTL_HOURS=24

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
# Origens permitidas, separadas por vírgula. Em dev, Vite roda em
# :5173. Em produção, troque pelo domínio real do frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ------------------------------------------------------------
# UPLOAD_DIR é configurado pelo docker-compose.yml diretamente
# (`UPLOAD_DIR: /app/uploads` no service `api`). Não precisa aqui.
# Pra rodar nativo, use `UPLOAD_DIR=uploads`.
# ------------------------------------------------------------
