# Variáveis de ambiente — segredos reais
.env

# Binários
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Output de testes
*.test
*.out
coverage.*

# IDE
.vscode/
.idea/
.claude/

# OS
.DS_Store
Thumbs.db

# Arquivos de upload (thumbnails e modelos 3D) — conteúdo de runtime,
# não pertence ao repo. A estrutura é recriada pelo LocalStorage no boot.
/uploads/

# Dumps do Postgres — contém dados de usuário (emails, hashes).
# Migrations versionadas continuam em /migrations/*.sql (não cobertas).
/backup*.sql
/dump*.sql
*.pgdump
